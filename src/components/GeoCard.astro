---
import GeoShape from "./GeoShape.astro";

type Shape = "ico" | "tetra" | "triangle" | "diamond" | "ring";
interface Props {
	title: string;
	shape?: Shape;
}
const { title, shape = "ico" } = Astro.props;
---

<article class="card sl-flex">
	<p class="title sl-flex">
		<GeoShape shape={shape} class="icon" />
		<span>{title}</span>
	</p>
	<div class="body"><slot /></div>
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		gap: clamp(0.5rem, calc(0.125rem + 1vw), 1rem);
		padding: clamp(1rem, calc(0.125rem + 3vw), 2.5rem);
	}
	.title {
		font-weight: 600;
		font-size: var(--sl-text-h4);
		color: var(--sl-color-white);
		line-height: var(--sl-line-height-headings);
		gap: 1rem;
		align-items: center;
	}
	.body {
		margin: 0;
		font-size: clamp(var(--sl-text-sm), calc(0.5rem + 1vw), var(--sl-text-body));
	}
</style>
