---
// Override of Starlight's splash Hero, restyled to match the marketing site
// (getbrainstorm.online): a mono `◇` eyebrow above the title, the same
// scattered hairline wireframe accents, and corner marks framing the page.
// Title / tagline / actions still come from the page frontmatter.
import { Image } from "astro:assets";
import { LinkButton } from "@astrojs/starlight/components";
import CornerMarks from "./CornerMarks.astro";
import GeoShape from "./GeoShape.astro";

// Starlight's reserved id for the page-title heading (../constants is not a
// public export, so the value is mirrored here).
const PAGE_TITLE_ID = "_top";

const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, image, actions = [] } = data.hero || {};

const imageAttrs = {
	loading: "eager" as const,
	decoding: "async" as const,
	width: 400,
	height: 400,
	alt: image?.alt || "",
};

let darkImage: ImageMetadata | undefined;
let lightImage: ImageMetadata | undefined;
let rawHtml: string | undefined;
if (image) {
	if ("file" in image) {
		darkImage = image.file;
	} else if ("dark" in image) {
		darkImage = image.dark;
		lightImage = image.light;
	} else {
		rawHtml = image.html;
	}
}
---

<CornerMarks />

<div class="hero">
	<div class="bs-hero-shapes" aria-hidden="true">
		<span class="hs hs-1"><GeoShape shape="tetra" /></span>
		<span class="hs hs-2"><GeoShape shape="triangle" /></span>
		<span class="hs hs-3"><GeoShape shape="diamond" /></span>
		<span class="hs hs-4"><GeoShape shape="ring" /></span>
	</div>

	{
		darkImage && (
			<Image
				src={darkImage}
				{...imageAttrs}
				class:list={{ "light:sl-hidden": Boolean(lightImage) }}
			/>
		)
	}
	{lightImage && <Image src={lightImage} {...imageAttrs} class="dark:sl-hidden" />}
	{rawHtml && <div class="hero-html sl-flex" set:html={rawHtml} />}

	<div class="sl-flex stack">
		<div class="sl-flex copy">
			<p class="bs-eyebrow"><span class="diamond" aria-hidden="true">◇</span> Local-first · AI-native</p>
			<h1 id={PAGE_TITLE_ID} data-page-title set:html={title} />
			{tagline && <div class="tagline" set:html={tagline} />}
		</div>
		{
			actions.length > 0 && (
				<div class="sl-flex actions">
					{actions.map(
						({ attrs: { class: className, ...attrs } = {}, icon, link: href, text, variant }) => (
							<LinkButton {href} {variant} icon={icon?.name} class:list={[className]} {...attrs}>
								{text}
								{icon?.html && <Fragment set:html={icon.html} />}
							</LinkButton>
						),
					)}
				</div>
			)
		}
	</div>
</div>

<style>
	.hero {
		position: relative;
		display: grid;
		grid-template-columns: 100%;
		align-items: center;
		gap: 1rem;
		padding-bottom: 1rem;
	}

	.hero > img,
	.hero > .hero-html {
		object-fit: contain;
		width: min(70%, 20rem);
		height: auto;
		margin-inline: auto;
	}

	.stack {
		position: relative;
		flex-direction: column;
		gap: clamp(1.5rem, calc(1.5rem + 1vw), 2rem);
		text-align: center;
	}

	.copy {
		flex-direction: column;
		gap: 1rem;
		align-items: center;
	}

	.copy > * {
		max-width: 55ch;
	}

	/* Mono `◇` eyebrow — mirrors the marketing-site hero eyebrow. */
	.bs-eyebrow {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		margin: 0;
		font-family: var(--sl-font-mono);
		font-size: var(--sl-text-xs);
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: var(--sl-color-text-accent);
	}
	.bs-eyebrow .diamond {
		color: var(--sl-color-accent);
		font-size: 0.9em;
		line-height: 1;
	}

	h1 {
		font-size: clamp(var(--sl-text-4xl), calc(0.25rem + 5.5vw), var(--sl-text-6xl));
		line-height: 1.05;
		letter-spacing: -0.025em;
		font-weight: 500;
		color: var(--sl-color-white);
	}

	.tagline {
		font-size: clamp(var(--sl-text-base), calc(0.0625rem + 2vw), var(--sl-text-xl));
		line-height: 1.4;
		color: var(--sl-color-gray-2);
	}

	.actions {
		gap: 1rem 1.5rem;
		flex-wrap: wrap;
		justify-content: center;
	}

	/* Scattered hairline wireframe accents (decorative). */
	.bs-hero-shapes {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}
	.hs {
		position: absolute;
		color: var(--sl-color-accent);
		opacity: 0.4;
	}
	.hs :global(svg) {
		width: var(--hs-size, 34px);
		height: var(--hs-size, 34px);
		stroke-width: 0.7;
	}
	.hs-1 {
		top: 4%;
		right: 6%;
		--hs-size: 44px;
	}
	.hs-2 {
		top: 60%;
		right: 30%;
		--hs-size: 26px;
		opacity: 0.3;
	}
	.hs-3 {
		bottom: 8%;
		right: 12%;
		--hs-size: 34px;
	}
	.hs-4 {
		top: 30%;
		right: 2%;
		--hs-size: 30px;
		opacity: 0.32;
	}

	@media (max-width: 50rem) {
		.bs-hero-shapes {
			display: none;
		}
	}

	@media (min-width: 50rem) {
		.hero {
			grid-template-columns: 7fr 4fr;
			gap: 3%;
			padding-block: clamp(2.5rem, calc(1rem + 10vmin), 9rem);
		}

		.hero > img,
		.hero > .hero-html {
			order: 2;
			width: min(100%, 25rem);
		}

		.stack {
			text-align: start;
		}

		.copy {
			align-items: flex-start;
		}

		.actions {
			justify-content: flex-start;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hs {
			display: none;
		}
	}
</style>
